meta {
  name: Register User (ADMIN/GENERAL)
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/users/register
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "email": "{{registerEmail}}",
    "password": "{{registerPassword}}",
    "fullName": "{{registerFullName}}",
    "nickname": "{{registerNickname}}",
    "role": "{{registerRole}}"
  }
}
