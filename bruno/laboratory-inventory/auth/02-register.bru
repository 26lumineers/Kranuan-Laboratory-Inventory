meta {
  name: Register
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/auth/register
  body: json
  auth: none
}

body:json {
  {
    "username": "{{registerUsername}}",
    "password": "{{registerPassword}}",
    "fullName": "{{registerFullName}}",
    "nickname": "{{registerNickname}}",
    "role": "{{registerRole}}"
  }
}
