meta {
  name: Create Transaction
  type: http
  seq: 3
}

post {
  url: {{baseUrl}}/transactions
  body: json
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

body:json {
  {
    "roomId": "{{roomId}}",
    "note": "Transaction note",
    "items": [
      {
        "productId": "{{productId}}",
        "quantity": 3
      }
    ]
  }
}
