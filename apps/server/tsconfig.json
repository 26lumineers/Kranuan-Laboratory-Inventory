{
    "compilerOptions": {
        "target": "ES2022",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "noEmit": true,
        "rootDir": "./src",
        "baseUrl": ".",
        "paths": {
            "@laboratory/db": ["../../packages/db/src"],
            "@laboratory/shared": ["../../packages/shared/src"]
        }
    },
    "include": ["src/**/*"],
    "exclude": ["node_modules"]
}
