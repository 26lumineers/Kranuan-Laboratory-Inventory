# Server Configuration
NODE_ENV=development
PORT=3001
HOST=0.0.0.0

# Database Configuration
# Option 1: Use full DATABASE_URL
DATABASE_URL=postgres://postgres:postgres@localhost:5432/laboratory_inventory

# Option 2: Use individual fields (DATABASE_URL takes precedence)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=laboratory_inventory
DB_USER=postgres
DB_PASSWORD=postgres

# JWT Configuration
JWT_SECRET=your-super-secret-key-change-in-production

# Logging
LOG_LEVEL=info
